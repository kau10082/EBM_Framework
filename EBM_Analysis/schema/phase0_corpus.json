{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 0 — 回顧問題 + corpus 相關性/角色分流",
  "description": "在逐篇評讀前，先定 review question，並判每篇的相關性與證據角色；決定走哪條評讀軌。也記錄 MA 的納入試驗（供統合去重）。",
  "type": "object",
  "additionalProperties": false,
  "required": ["review_question", "papers"],
  "properties": {
    "review_question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "P", "I", "C", "O"],
      "properties": {
        "statement": { "type": "string" },
        "P": { "type": "string" },
        "I": { "type": "string" },
        "C": { "type": "string" },
        "O": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "outcomes_prioritized": {
          "type": "array", "maxItems": 7,
          "description": "事前 outcome 排序(Ch3 §3.2.4 C14-C18)：最多 7 個、含至少一益一害、標 critical/important、註明測量工具/時點。",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["name", "importance"],
            "properties": {
              "name": {"type": "string"},
              "importance": {"enum": ["critical", "important", "not_important"]},
              "direction": {"enum": ["benefit", "harm", "both"]},
              "measure_timepoint": {"type": ["string", "null"]}
            }
          }
        },
        "eligibility": {
          "type": ["object", "null"], "additionalProperties": false,
          "description": "事前合格條件(Ch3 §3.2 C5-C11)：設計合格條件＋理由、部分合格參與者處理策略。",
          "properties": {
            "study_designs": {"type": ["string", "null"]},
            "design_rationale": {"type": ["string", "null"]},
            "partial_eligibility_strategy": {"type": ["string", "null"]}
          }
        }
      }
    },
    "papers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["paper_id", "relevance", "role", "grade_track"],
        "properties": {
          "paper_id": { "type": "string" },
          "title": { "type": "string" },
          "doi": { "type": ["string", "null"], "description": "自交接包 _corpus_seed 帶入（ingest_seed 寫入；analysis_scope 列需補全文清單用）——曾不在白名單，ingest 產的草稿被本 schema 必拒" },
          "pmid": { "type": ["string", "null"], "description": "自交接包 _corpus_seed 帶入（同 doi）" },
          "relevance": {
            "enum": ["direct", "indirect", "background", "excluded"],
            "description": "相對於 review_question 的相關性"
          },
          "role": {
            "enum": ["pivotal_efficacy", "meta_analysis", "safety", "supportive_secondary",
                     "mechanism_pd", "pharmacokinetic", "narrative_review", "other"],
            "description": "證據角色"
          },
          "design": { "type": ["string", "null"], "description": "RCT/SR-MA/NRSI/Phase I/review…" },
          "is_primary_report": { "type": "boolean", "description": "是否為該 Study 的主要報告（分析錨點）。同一試驗多報告中只一篇為 true；分析以它為全文錨點，其餘為 overlap 次級報告。用於 analysis_scope 算『需補全文』最小集（每 Study 一篇）。" },
          "grade_track": {
            "enum": ["full", "targeted_harms", "light_summary", "none"],
            "description": "full=跑完整四階段；targeted_harms=只評 harms；light_summary=背景摘要不分級；none=排除"
          },
          "included_trials": {
            "type": "array",
            "description": "僅 meta_analysis：其納入的原始試驗 id/名稱（供統合去重、查重疊）",
            "items": { "type": "string" }
          },
          "overlap_with": {
            "type": "array",
            "description": "與哪些 paper_id 共用底層資料（如同一試驗的次分析/子群）",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        }
      }
    },
    "overlap_notes": { "type": "string", "description": "整體重疊/雙重計算風險摘要" }
  }
}
