{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 4 — 輸出（單篇報告 + 統合）的結構化真相來源",
  "description": "人讀報告由本物件渲染，確保報告不與判定漂移。",
  "type": "object",
  "additionalProperties": false,
  "required": ["per_paper", "synthesis"],
  "definitions": {
    "sof_row": {
      "type": "object",
      "additionalProperties": true,
      "description": "SoF 單列（per-track 共用；欄位同主 sof）",
      "required": ["outcome", "assumed_control_risk", "corresponding_risk", "absolute_effect", "relative_effect", "n_participants_studies", "certainty"],
      "properties": {
        "outcome": { "type": "string" },
        "assumed_control_risk": { "type": "string" },
        "corresponding_risk": { "type": "string" },
        "absolute_effect": { "type": "string" },
        "relative_effect": { "type": "string" },
        "n_participants_studies": { "type": "string" },
        "certainty": { "type": "string" },
        "comment": { "type": ["string", "null"] }
      }
    }
  },
  "properties": {
    "per_paper": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["paper_id", "pico", "bottom_line", "dashboard", "caveats", "selfcheck_pass"],
        "properties": {
          "paper_id": { "type": "string" },
          "pico": { "type": "string" },
          "bottom_line": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text", "certainty", "wording_tier"],
            "properties": {
              "text": { "type": "string" },
              "certainty": { "enum": ["high", "moderate", "low", "very_low"] },
              "wording_tier": { "enum": ["直述", "likely", "may", "非常不確定"], "description": "wording_template 一致性" }
            }
          },
          "dashboard": { "type": "string", "description": "APA + 方括號【GRADE/起始設計/升降領域/N/方法學】；禁效果數據與 p 值" },
          "caveats": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "surrogate":    { "type": ["string", "null"] },
              "harms":        { "type": ["string", "null"] },
              "coi":          { "type": ["string", "null"] },
              "imprecision":  { "type": ["string", "null"] },
              "nma":          { "type": ["string", "null"] },
              "nonreporting": { "type": ["string", "null"] }
            }
          },
          "computation_checks": { "type": "array", "items": { "type": "string" } },
          "selfcheck_pass": { "type": "boolean", "description": "output_selfcheck gate；false 不得輸出" }
        }
      }
    },
    "synthesis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["consistency", "vote_counting_check", "conflict_analysis", "weight_adjudication"],
      "properties": {
        "tracks": {
          "type": "object",
          "additionalProperties": false,
          "description": "多軌並行整合（暫存/交付容器）：三軌絕不混池、不混 GRADE、不混同一森林圖。每軌獨立 pool/forest/SoF/起始確定性。整合運算規則見 guardrails/multitrack_integration.md。機器看守 validate.py check_synthesis_tracks。",
          "properties": {
            "rct": {
              "type": "object", "additionalProperties": false,
              "description": "第一軌：RCT（RoB2）＝主力。主分析統合＋專屬森林圖；起始 high。",
              "required": ["tool", "synthesis_mode", "included_paper_ids", "starting_certainty"],
              "properties": {
                "tool": { "const": "rob2" },
                "synthesis_mode": { "enum": ["meta_analysis", "narrative"] },
                "included_paper_ids": { "type": "array", "items": { "type": "string" } },
                "excluded_ids": { "type": "array", "items": { "type": "string" }, "description": "敏感度分析剔除之高風險研究（仍屬本軌，非跨軌）" },
                "forest_plot": { "type": ["string", "null"] },
                "sensitivity_analysis": { "type": ["string", "null"], "description": "依 RoB 高低分層/剔除高風險的穩健性分析" },
                "starting_certainty": { "const": "high" },
                "sof": { "type": "array", "maxItems": 7, "items": { "$ref": "#/definitions/sof_row" } },
                "certainty_summary": { "type": ["string", "null"] }
              }
            },
            "nrsi": {
              "type": "object", "additionalProperties": false,
              "description": "第二軌：NRSI（ROBINS-I）＝真實世界輔助。獨立森林圖，絕不與 RCT 合併；critical 必剔除；異質性大改敘事綜整；起始 low（ROBINS-I 可 high 但常降至 low/very_low）。",
              "required": ["tool", "synthesis_mode", "included_paper_ids", "excluded_critical_ids", "starting_certainty"],
              "properties": {
                "tool": { "const": "robins_i" },
                "synthesis_mode": { "enum": ["meta_analysis", "narrative"], "description": "異質性過大→narrative（放棄統計合併）" },
                "included_paper_ids": { "type": "array", "items": { "type": "string" } },
                "excluded_critical_ids": { "type": "array", "items": { "type": "string" }, "description": "ROBINS-I=critical 者必列於此、且不得進 included（Cochrane Ch.25）" },
                "forest_plot": { "type": ["string", "null"] },
                "starting_certainty": { "enum": ["low", "high"] },
                "sof": { "type": "array", "maxItems": 7, "items": { "$ref": "#/definitions/sof_row" } },
                "certainty_summary": { "type": ["string", "null"] }
              }
            },
            "srma_context": {
              "type": "object", "additionalProperties": false,
              "description": "第三軌：既有 SR/MA（AMSTAR2）＝討論對照基準。非 Overview 時，絕不作數據提取來源、不進統合（防 double-counting），僅於討論章節對照。",
              "required": ["used_as_data_source", "role", "reviews"],
              "properties": {
                "used_as_data_source": { "const": false, "description": "鐵則：一般 SR 不可把他人 SR/MA 當數據源池化（除非本研究就是 Overview）" },
                "role": { "const": "discussion_context" },
                "is_overview": { "type": "boolean", "description": "若本研究即『回顧之綜覽 Overview』則 true（此時 SR/MA 才可為分析單位，另循 overview 流程）" },
                "reviews": {
                  "type": "array",
                  "items": {
                    "type": "object", "additionalProperties": false,
                    "required": ["review", "amstar2_rating", "agreement"],
                    "properties": {
                      "review": { "type": "string" },
                      "amstar2_rating": { "enum": ["high", "moderate", "low", "critically_low"] },
                      "scope": { "type": ["string", "null"] },
                      "agreement": { "enum": ["concordant", "discordant", "updates", "unclear"], "description": "與本研究 RCT/NRSI 結果的關係：一致/相左/更新翻轉/不明" },
                      "note": { "type": ["string", "null"] }
                    }
                  }
                }
              }
            },
            "integration_note": { "type": ["string", "null"], "description": "分層結論：首要(RCT high)→次要支持(NRSI low,方向)→脈絡對照(SR/MA)。整合運算規則待補。" }
          }
        },
        "consistency": { "type": "string", "description": "依效果估計收斂，非結論篇數" },
        "vote_counting_check": { "type": "string", "description": "vote_counting 三層可取性" },
        "swim_check":        { "type": ["string", "null"] },
        "overlap_check":     { "type": ["string", "null"] },
        "nma_check":         { "type": ["string", "null"] },
        "conflict_analysis": { "type": "string" },
        "weight_adjudication": { "type": "string", "description": "依 GRADE/RoB/一致性；不以 N 規模/期刊名" },
        "report_title": { "type": ["string", "null"], "description": "最終報告標題" },
        "plain_summary": { "type": ["string", "null"], "description": "★白話總結（通勤可讀，FINAL_REPORT/PDF 開頭 lead 段）：3–5 句、口語流暢，30 秒看完『結論是什麼、給誰、要注意什麼』；術語就地白話化（NNTB→大約治療幾人能多幫到 1 人）。只改表達、不弱化判定/方向/不確定性。" },
        "bottom_line": { "type": "array", "items": { "type": "string" }, "description": "總結要點（FINAL_REPORT 自動渲染用）" },
        "clinical_one_liner": { "type": ["string", "null"], "description": "給臨床的一句話" },
        "study_characteristics": {
          "type": "array",
          "description": "納入研究特徵表（report_completeness）",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["trial", "drug", "phase", "n", "dose", "duration", "comparator", "primary_outcome"],
            "properties": {
              "trial": {"type": "string"}, "drug": {"type": "string"}, "phase": {"type": "string"},
              "n": {"type": "string"}, "dose": {"type": "string"}, "duration": {"type": "string"},
              "comparator": {"type": "string"}, "primary_outcome": {"type": "string"},
              "design_detail": {"type": "string", "description": "研究設計逐篇描述（如『多中心雙盲平行 RCT』『回溯性世代(NRSI)』）——renderer 讀此欄；缺值只印 phase，不得偽造設計"}
            }
          }
        },
        "evidence_base_label": {"type": ["string", "null"], "description": "證據基礎量詞標籤（如『項隨機對照試驗』『項研究（含 NRSI）』）——renderer 讀此欄；曾因本鍵不在契約內（additionalProperties:false 必拒）使設計感知路徑成死碼、NRSI 被回退值誤稱 RCT"},
        "screening_flow": {
          "type": "array",
          "description": "PRISMA-style 篩選流程（build_screening_flow 自動帶入或手填）；renderer 會把本鍵寫回 _synthesis.json，故必須在契約內，否則跑過一次渲染 verify_all schema gate 必 ❌",
          "items": {
            "type": "object",
            "properties": {
              "stage": {"type": "string"}, "start": {"type": "string"}, "excluded": {"type": "string"},
              "remain": {"type": "string"}, "note": {"type": ["string", "null"]}
            }
          }
        },
        "rob_section": {
          "type": "object", "additionalProperties": false,
          "description": "第二段（偏誤風險）版型覆寫：NRSI/ROBINS-I 軌可自訂標題/導語/欄名（renderer 讀此欄；缺時用 RoB2 預設）",
          "properties": {
            "title": {"type": "string"}, "intro": {"type": "string"},
            "columns": {"type": "array", "items": {"type": "string"}, "maxItems": 8},
            "colwidths": {"type": "array", "items": {"type": "number"}, "minItems": 8, "maxItems": 8}
          }
        },
        "rob_summary": {
          "type": "array",
          "description": "RoB 2 逐領域摘要（report_completeness）",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["trial", "randomization", "deviations", "missing_data", "measurement", "selective_reporting", "overall"],
            "properties": {
              "trial": {"type": "string"}, "randomization": {"type": "string"}, "deviations": {"type": "string"},
              "missing_data": {"type": "string"}, "measurement": {"type": "string"},
              "selective_reporting": {"type": "string"}, "overall": {"type": "string"},
              "evidence_basis": {"type": "string", "description": "抽取資料來源(full_text/abstract/ai_synthesis/registry)；非全文者 RoB2 overall 不得 low(selfcheck C4)"},
              "registry_check": {"type": "string", "description": "註冊 vs 發表主要結果比對結果(selective_reporting/Domain5)"},
              "note": {"type": "string", "description": "some concerns 原因註記(逐領域)；overall=low 可寫『各領域皆 low』"}
            }
          }
        },
        "related_reviews": {
          "type": "array",
          "description": "相關 SR/MA 特徵＋AMSTAR 2 評級（amstar2 護欄）。與 4 RCT『納入研究特徵表』分離，維持 study-vs-review 單位區分（Ch V）；去重後不與個別 RCT 結論疊加（overlap_indirect）",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["review", "scope", "trials_covered", "amstar2_rating", "role"],
            "properties": {
              "review": {"type": "string", "description": "作者年代＋類型（如 Emara 2025 MA）"},
              "scope": {"type": "string", "description": "涵蓋範圍（藥物／結果）"},
              "trials_covered": {"type": "string", "description": "納入之原始試驗"},
              "amstar2_rating": {"enum": ["high", "moderate", "low", "critically_low"], "description": "AMSTAR 2 整體信心（依關鍵領域缺陷數）"},
              "amstar2_basis": {"type": ["string", "null"], "description": "評級依據：滿足/未滿足之關鍵領域（註冊/檢索/RoB/方法/發表偏誤/RoB入詮釋/排除清單）"},
              "role": {"type": "string", "description": "在本報告中的角色（如校準／類別層級參照）"}
            }
          }
        },
        "literature_status": {
          "type": "array",
          "description": "納入文獻狀態表（流程圖後）：每篇角色＋全文取得狀態（尤其有無全文）。供 report_completeness 透明度",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["paper", "role", "fulltext"],
            "properties": {
              "paper": {"type": "string"}, "role": {"type": "string"},
              "fulltext": {"type": "string", "description": "全文取得：有全文(線上OA/本機人工補)／僅AI合成摘要／僅書目"}
            }
          }
        },
        "body_of_evidence": {
          "type": "array",
          "description": "★證據體 GRADE（Ch14 §14.2.1）：逐 outcome 對『合併後該結果跨研究』重評確定性，非逐篇分數取均/取最差。不一致性=跨研究、不精確=合併 CI vs MID/OIS、發表偏誤=跨研究。",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["outcome", "certainty", "basis"],
            "properties": {
              "outcome": {"type": "string"},
              "certainty": {"enum": ["high", "moderate", "low", "very_low"]},
              "basis": {"type": "string", "description": "確定性如何由跨研究證據體導出(五領域於證據體層之判斷摘要)"}
            }
          }
        },
        "missing_evidence_sensitivity": { "type": ["string", "null"], "description": "缺失證據敏感度分析(ROB-ME；Ch13)：假設未發表/進行中研究為 null，估計合併效應是否被稀釋/翻轉，作為發表偏誤降級之佐證(非僅以『廠商資助』籠統降級)" },
        "meta_analysis": {
          "type": "array",
          "description": "數據綜整/統合分析(Ch10)：逐 core outcome 的池化合併效應＋異質性。未池化者以 model='not_pooled' 並於 heterogeneity 說明理由(如對照藥不同/僅摘要)。",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["outcome", "model", "pooled_effect", "heterogeneity"],
            "properties": {
              "outcome": {"type": "string"},
              "model": {"enum": ["fixed", "random", "not_pooled"], "description": "固定/隨機效應；not_pooled=未池化(敘述綜整)"},
              "k_studies": {"type": ["integer", "string", "null"], "description": "納入合併之研究數"},
              "pooled_effect": {"type": "string", "description": "合併效應量＋類型(如『RR 0.76』)；未池化寫逐試驗範圍"},
              "ci": {"type": ["string", "null"], "description": "95% CI"},
              "i2": {"type": ["string", "null"], "description": "I^2 異質性(如『0%』)；未池化可 null"},
              "heterogeneity": {"type": "string", "description": "異質性判讀＋來源解釋(統計＋臨床)；未池化在此說明理由"},
              "per_study": {"type": ["string", "null"], "description": "逐試驗效應量列示"},
              "absolute": {"type": ["string", "null"], "description": "絕對效應換算(每千人/率差)"}
            }
          }
        },
        "prisma_attest": { "type": ["object", "null"], "additionalProperties": { "type": "string" }, "description": "PRISMA 2020 人工聲明項(鍵=項號字串，如 \"24\")，供 prisma_audit 將回顧層 MANUAL 項(註冊/資金/利益衝突/資料蒐集流程/可得性)轉 ATTEST。" },
        "sof_footnotes": { "type": "array", "items": { "type": "string" }, "description": "GRADE 降級腳註(a/b/c…，Ch14 §14.2)：對應 SoF 各列 certainty 之降級理由，逐條列示(偏誤/不一致/間接/不精確/發表偏誤或資料不足)。" },
        "publication_bias": { "type": ["string", "null"], "description": "發表偏誤/缺失證據聲明（<10 不畫漏斗圖）" },
        "subgroup_implications": { "type": ["string", "null"], "description": "次群組＋對研究的意涵" },
        "baseline_risk_strata": {
          "type": "array",
          "description": "基準風險分層的絕對效應",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["baseline_risk", "corresponding", "absolute_reduction"],
            "properties": {
              "baseline_risk": {"type": "string"}, "corresponding": {"type": "string"}, "absolute_reduction": {"type": "string"}
            }
          }
        },
        "limitations": { "type": "array", "items": { "type": "string" }, "description": "限制與尚待釐清" },
        "sof": {
          "type": "array",
          "description": "Summary of Findings 表（sof_table 護欄）：最多 7 個病患重要結果；二分類須相對＋絕對並列",
          "maxItems": 7,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["outcome", "assumed_control_risk", "corresponding_risk", "absolute_effect", "relative_effect", "n_participants_studies", "certainty"],
            "properties": {
              "outcome": { "type": "string", "description": "結果＋測量時框" },
              "assumed_control_risk": { "type": "string", "description": "對照組基線風險/率（註明來源）" },
              "corresponding_risk": { "type": "string", "description": "介入組對應風險/率（由相對效應×基線導出）" },
              "absolute_effect": { "type": "string", "description": "風險差/NNT（二分類）或率差（rate）；連續結果標 MD" },
              "relative_effect": { "type": "string", "description": "RR/OR/HR＋95% CI" },
              "n_participants_studies": { "type": "string", "description": "參與者數（研究數）" },
              "certainty": { "enum": ["high", "moderate", "low", "very_low"] },
              "comment": { "type": ["string", "null"], "description": "如替代終點侷限、單藥 vs 類別" },
              "mid": { "type": ["string", "null"], "description": "連續結果之最小重要差異 MID/MCID（Ch14 §14.1.6.2 應每結果註明）；不精確以 CI 是否跨 MID 判定(Ch15 §15.5)" },
              "continuous_reexpression": { "type": ["string", "null"], "description": "連續結果可解讀再表達(熟悉量表/平均值之比/MID 單位/二分化 logOR≈1.81×SMD；Ch15 §15.5.3)" },
              "dose_response": { "type": ["string", "null"], "description": "劑量反應梯度(危害/益處不可只用單一劑量代表類別；Ch14 lumping/splitting＋GRADE 上調領域)" },
              "provenance": {
                "type": ["array", "null"],
                "description": "★數字溯源(反幻覺)：本列關鍵數值各附原文 quote＋來源，供 quote_verify 回全文機器核對。直接建 synthesis(未走 p1.json)時尤其必要。",
                "items": {
                  "type": "object", "additionalProperties": false,
                  "required": ["value", "quote", "source"],
                  "properties": {
                    "value": { "type": "string", "description": "對應的數值(如 'HR 0.58' / 'NNTH 44' / '死亡 7 (1.2%)')" },
                    "quote": { "type": "string", "description": "原文逐字片段(英文照錄)，quote_verify 會回 source 全文模糊比對" },
                    "source": { "type": "string", "description": "來源 paper_id 或 DOI(去斜線檔名亦可)，供解析 fulltext_channel 取全文" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
